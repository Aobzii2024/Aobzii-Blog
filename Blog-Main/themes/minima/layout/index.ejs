<section class="home-hero">
  <div class="home-avatar-wrap">
    <img src="<%- url_for('/images/main.jpg') %>" alt="<%= theme.owner %>" class="about mb-3" width="150" height="150" decoding="async" fetchpriority="high">
  </div>
  <div class="home-hero-copy">
    <p class="eyebrow">Personal Notes</p>
    <h2 class="mb-2"><%= theme.owner %></h2>
    <p><%= theme.info %></p>
    <p><%= theme.desc %></p>
  </div>
</section>

<section class="home-section">
  <div class="section-heading-row">
    <h3>最近文章</h3>
    <a href="<%= config.root %>archives" class="interactive-link section-more">查看全部</a>
  </div>

  <% site.posts.sort('date', 'desc').limit(theme.max_post).forEach(function(post){ %>
  <div class="row home-post-row">
    <div class="three columns left lit home-post-date">
      <p class="bottom"><%- full_date(post.date, 'll') %></p>
    </div>
    <div class="nine columns left mb-3 home-post-title">
      <a href="<%- url_for(post.path) %>" class="interactive-link">
        <% if (post.title === '') { %>
          未命名
        <% } else { %>
          <%- post.title %>
        <% } %>
      </a>
    </div>
  </div>
  <% }) %>
</section>
